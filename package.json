{
  "name": "comfy-client-cli",
  "version": "1.0.0",
  "description": "ComfyUI 命令行工具 - 管理、配置和运行 ComfyUI 工作流",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ccc": "./dist/index.js",
    "comfy-client-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "link": "npm link"
  },
  "keywords": [
    "comfyui",
    "cli",
    "workflow",
    "ai",
    "image-generation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mailzwj/comfy-client-cli.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.3",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
